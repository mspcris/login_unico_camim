<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Usuários — Painel Camim</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="admin-layout">

    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="admin-sidebar-logo">
        <svg width="90" height="30" viewBox="0 0 120 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <text x="0" y="32" font-family="system-ui, -apple-system, sans-serif" font-size="30" font-weight="700" fill="#ffffff">Camim</text>
        </svg>
        <span>Admin</span>
      </div>
      <nav>
        <a href="/painel/usuarios" class="active">Usuários</a>
        <a href="/painel/dominios">Domínios</a>
        <a href="/painel/logout">Sair</a>
      </nav>
    </aside>

    <!-- Main content -->
    <main class="admin-main">
      <div class="admin-header">
        <h1>Usuários</h1>
        <p style="color: var(--text-secondary); font-size: 0.875rem; margin-top: 4px;">
          Gerencie as contas de usuário do Login Único Camim
        </p>
      </div>

      <!-- Flash messages -->
      <% if (success) { %>
        <div class="flash-success"><%= success %></div>
      <% } %>
      <% if (error) { %>
        <div class="flash-error"><%= error %></div>
      <% } %>

      <!-- Invite form -->
      <div class="table-container" style="margin-bottom: 24px; padding: 20px 24px;">
        <h2 style="font-size: 1rem; font-weight: 600; color: var(--text-primary); margin-bottom: 14px;">Convidar novo usuário</h2>
        <form action="/painel/usuarios/convidar" method="POST" class="form-inline">
          <input
            type="email"
            name="email"
            required
            placeholder="email@dominio.com.br"
            class="form-input"
            style="margin-bottom: 0;"
          />
          <button type="submit" class="btn-primary" style="width: auto; margin-top: 0; white-space: nowrap;">
            Enviar convite
          </button>
        </form>
      </div>

      <!-- Users table -->
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Nome</th>
              <th>E-mail</th>
              <th>Status</th>
              <th>Admin</th>
              <th>Criado em</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% if (users.length === 0) { %>
              <tr>
                <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 32px;">
                  Nenhum usuário encontrado.
                </td>
              </tr>
            <% } %>
            <% users.forEach(function(u) { %>
              <tr>
                <td><%= u.name || '—' %></td>
                <td><%= u.email %></td>
                <td>
                  <% if (u.active && u.name) { %>
                    <span class="badge badge-active">Ativo</span>
                  <% } else if (!u.active && u.has_pending_token) { %>
                    <span class="badge badge-pending">Pendente</span>
                  <% } else if (!u.active) { %>
                    <span class="badge badge-inactive">Inativo</span>
                  <% } else { %>
                    <span class="badge badge-active">Ativo</span>
                  <% } %>
                </td>
                <td>
                  <% if (u.is_admin) { %>
                    <span class="badge badge-active">Sim</span>
                  <% } else { %>
                    <span style="color: var(--text-muted);">Não</span>
                  <% } %>
                </td>
                <td style="font-size: 0.8125rem; color: var(--text-secondary);">
                  <%= new Date(u.created_at).toLocaleDateString('pt-BR') %>
                </td>
                <td>
                  <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                    <% if (u.active) { %>
                      <form action="/painel/usuarios/<%= u.id %>/desativar" method="POST" style="display:inline;">
                        <button type="submit" class="btn-sm btn-sm-danger" onclick="return confirm('Desativar este usuário?')">Desativar</button>
                      </form>
                    <% } else { %>
                      <form action="/painel/usuarios/<%= u.id %>/ativar" method="POST" style="display:inline;">
                        <button type="submit" class="btn-sm btn-sm-primary">Ativar</button>
                      </form>
                    <% } %>
                    <% if (!u.active || u.has_pending_token) { %>
                      <form action="/painel/usuarios/<%= u.id %>/reenviar" method="POST" style="display:inline;">
                        <button type="submit" class="btn-sm btn-sm-secondary">Reenviar convite</button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </main>

  </div>
</body>
</html>
