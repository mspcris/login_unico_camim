<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Usuários — Painel Camim</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <!-- Mobile top bar -->
  <div class="topbar">
    <div class="topbar-brand">Camim <span class="topbar-badge">Admin</span></div>
    <button class="topbar-hamburger" onclick="toggleSidebar()" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="sidebar-overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>

  <div class="admin-layout">
    <aside class="admin-sidebar" id="admin-sidebar">
      <div class="sidebar-brand">
        <span class="sidebar-brand-name">Camim</span>
        <span class="sidebar-brand-badge">Admin</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/painel/usuarios" class="active">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Usuários
        </a>
        <a href="/painel/dominios">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Domínios
        </a>
        <a href="/painel/sistemas">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          Sistemas
        </a>
      </nav>
      <div class="sidebar-footer">
        <a href="/painel/logout" class="sidebar-logout">
          <svg width="17" height="17" fill="none" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Sair
        </a>
      </div>
    </aside>

    <main class="admin-main">
      <div class="admin-header">
        <h1>Usuários</h1>
        <p>Gerencie as contas de acesso ao Login Único Camim.</p>
      </div>

      <% if (success) { %>
        <div class="flash-success">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <%= success %>
        </div>
      <% } %>
      <% if (error) { %>
        <div class="flash-error">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          <%= error %>
        </div>
      <% } %>

      <!-- Convidar -->
      <div class="table-container" style="margin-bottom:24px;padding:20px 24px;">
        <h2 style="font-size:1rem;font-weight:600;color:var(--text-primary);margin-bottom:14px;">Convidar novo usuário</h2>
        <form action="/painel/usuarios/convidar" method="POST" class="form-inline">
          <input type="email" name="email" required placeholder="email@dominio.com.br" class="form-input" style="margin-bottom:0;" />
          <button type="submit" class="btn-primary" style="width:auto;margin-top:0;white-space:nowrap;">Enviar convite</button>
        </form>
      </div>

      <!-- Tabela -->
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Nome</th>
              <th>E-mail</th>
              <th>Status</th>
              <th>Admin</th>
              <th>Criado em</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% if (users.length === 0) { %>
              <tr><td colspan="6" style="text-align:center;color:var(--text-muted);padding:32px;">Nenhum usuário encontrado.</td></tr>
            <% } %>
            <% users.forEach(function(u) { %>
              <tr>
                <td data-label="Nome"><%= u.name || '—' %></td>
                <td data-label="E-mail" style="font-size:0.875rem;"><%= u.email %></td>
                <td data-label="Status">
                  <% if (u.active && u.name) { %>
                    <span class="badge badge-active">Ativo</span>
                  <% } else if (!u.active && u.has_pending_token) { %>
                    <span class="badge badge-pending">Pendente</span>
                  <% } else if (!u.active) { %>
                    <span class="badge badge-inactive">Inativo</span>
                  <% } else { %>
                    <span class="badge badge-active">Ativo</span>
                  <% } %>
                </td>
                <td data-label="Admin">
                  <% if (u.is_admin) { %>
                    <span class="badge badge-admin">Admin</span>
                  <% } else { %>
                    <span style="color:var(--text-muted);font-size:0.875rem;">—</span>
                  <% } %>
                </td>
                <td data-label="Criado em" style="font-size:0.8125rem;color:var(--text-secondary);white-space:nowrap;">
                  <%= new Date(u.created_at).toLocaleDateString('pt-BR') %>
                </td>
                <td class="td-actions">
                  <button type="button" class="btn-sm btn-sm-secondary"
                    data-id="<%= u.id %>"
                    data-name="<%= u.name || '' %>"
                    data-email="<%= u.email %>"
                    data-admin="<%= u.is_admin ? '1' : '0' %>"
                    onclick="abrirEditarUsuario(this)">Editar</button>
                  <% if (u.active) { %>
                    <form action="/painel/usuarios/<%= u.id %>/desativar" method="POST" style="display:inline;"
                      onsubmit="return confirm('Desativar este usuário?')">
                      <button type="submit" class="btn-sm btn-sm-danger">Desativar</button>
                    </form>
                  <% } else { %>
                    <form action="/painel/usuarios/<%= u.id %>/ativar" method="POST" style="display:inline;">
                      <button type="submit" class="btn-sm btn-sm-primary">Ativar</button>
                    </form>
                  <% } %>
                  <% if (!u.active || u.has_pending_token) { %>
                    <form action="/painel/usuarios/<%= u.id %>/reenviar" method="POST" style="display:inline;">
                      <button type="submit" class="btn-sm btn-sm-secondary">Reenviar</button>
                    </form>
                  <% } %>
                  <form action="/painel/usuarios/<%= u.id %>/excluir" method="POST" style="display:inline;"
                    data-email="<%= u.email %>"
                    onsubmit="return confirm('Excluir permanentemente ' + this.dataset.email + '? Não pode ser desfeito.')">
                    <button type="submit" class="btn-sm" style="background:#7f1d1d;color:#fff;">Excluir</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </main>
  </div>

  <!-- Modal Editar Usuário -->
  <div class="modal-overlay" id="modal-usuario">
    <div class="modal-box">
      <div class="modal-title">Editar usuário</div>
      <form id="form-usuario" method="POST">
        <div class="modal-field">
          <label>Nome</label>
          <input type="text" id="eu-name" name="name" class="form-input" placeholder="Nome completo" />
        </div>
        <div class="modal-field">
          <label>E-mail</label>
          <input type="email" id="eu-email" name="email" required class="form-input" />
        </div>
        <div class="modal-field">
          <label class="modal-check">
            <input type="checkbox" id="eu-admin" name="is_admin" value="1" />
            Conceder acesso de administrador
          </label>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn-modal-cancel" onclick="fecharModal('modal-usuario')">Cancelar</button>
          <button type="submit" class="btn-primary" style="width:auto;margin:0;padding:9px 22px;">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('admin-sidebar').classList.toggle('open');
      document.getElementById('sidebar-overlay').classList.toggle('open');
    }
    function fecharModal(id) {
      document.getElementById(id).classList.remove('open');
    }
    function abrirEditarUsuario(btn) {
      document.getElementById('eu-name').value    = btn.dataset.name;
      document.getElementById('eu-email').value   = btn.dataset.email;
      document.getElementById('eu-admin').checked = btn.dataset.admin === '1';
      document.getElementById('form-usuario').action = '/painel/usuarios/' + btn.dataset.id + '/editar';
      document.getElementById('modal-usuario').classList.add('open');
    }
    document.getElementById('modal-usuario').addEventListener('click', function(e) {
      if (e.target === this) fecharModal('modal-usuario');
    });
  </script>
</body>
</html>
