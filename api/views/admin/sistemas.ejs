<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sistemas — Painel Camim</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <!-- Mobile top bar -->
  <div class="topbar">
    <div class="topbar-brand">Camim <span class="topbar-badge">Admin</span></div>
    <button class="topbar-hamburger" onclick="toggleSidebar()" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="sidebar-overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>

  <div class="admin-layout">
    <aside class="admin-sidebar" id="admin-sidebar">
      <div class="sidebar-brand">
        <span class="sidebar-brand-name">Camim</span>
        <span class="sidebar-brand-badge">Admin</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/painel/usuarios">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Usuários
        </a>
        <a href="/painel/dominios">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Domínios
        </a>
        <a href="/painel/sistemas" class="active">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          Sistemas
        </a>
      </nav>
      <div class="sidebar-footer">
        <a href="/painel/logout" class="sidebar-logout">
          <svg width="17" height="17" fill="none" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Sair
        </a>
      </div>
    </aside>

    <main class="admin-main">
      <div class="admin-header">
        <h1>Sistemas</h1>
        <p>Registre sistemas que usarão o Login Único Camim (idCamim).</p>
      </div>

      <!-- Credenciais geradas (mostradas UMA vez) -->
      <% if (newClient) { %>
        <div style="background:#f0fdf4;border:2px solid #16a34a;border-radius:10px;padding:24px;margin-bottom:28px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="12" fill="#16a34a"/><path d="M7 12.5l3.5 3.5 6.5-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <strong style="color:#15803d;font-size:1rem;">Sistema registrado! Copie as credenciais agora — o client_secret não será exibido novamente.</strong>
          </div>
          <div style="display:flex;flex-direction:column;gap:10px;">
            <div>
              <label style="font-size:0.8rem;font-weight:600;color:#166534;text-transform:uppercase;letter-spacing:.05em;">client_id</label>
              <div style="display:flex;gap:8px;margin-top:4px;">
                <code id="new-client-id" style="flex:1;background:#fff;border:1.5px solid #86efac;border-radius:6px;padding:10px 14px;font-size:0.875rem;word-break:break-all;"><%= newClient.client_id %></code>
                <button onclick="copyText('new-client-id')" style="background:#16a34a;color:#fff;border:none;border-radius:6px;padding:0 14px;cursor:pointer;font-size:0.85rem;white-space:nowrap;">Copiar</button>
              </div>
            </div>
            <div>
              <label style="font-size:0.8rem;font-weight:600;color:#166534;text-transform:uppercase;letter-spacing:.05em;">client_secret</label>
              <div style="display:flex;gap:8px;margin-top:4px;">
                <code id="new-client-secret" style="flex:1;background:#fff;border:1.5px solid #86efac;border-radius:6px;padding:10px 14px;font-size:0.875rem;word-break:break-all;"><%= newClient.client_secret %></code>
                <button onclick="copyText('new-client-secret')" style="background:#16a34a;color:#fff;border:none;border-radius:6px;padding:0 14px;cursor:pointer;font-size:0.85rem;white-space:nowrap;">Copiar</button>
              </div>
            </div>
            <div>
              <label style="font-size:0.8rem;font-weight:600;color:#166534;text-transform:uppercase;letter-spacing:.05em;">Discovery URL</label>
              <div style="display:flex;gap:8px;margin-top:4px;">
                <code id="discovery-url" style="flex:1;background:#fff;border:1.5px solid #86efac;border-radius:6px;padding:10px 14px;font-size:0.875rem;word-break:break-all;"><%= issuer %>/.well-known/openid-configuration</code>
                <button onclick="copyText('discovery-url')" style="background:#16a34a;color:#fff;border:none;border-radius:6px;padding:0 14px;cursor:pointer;font-size:0.85rem;white-space:nowrap;">Copiar</button>
              </div>
            </div>
          </div>
          <p style="margin-top:16px;font-size:0.85rem;color:#166534;">
            Adicione <strong>IDCAMIM_CLIENT_ID</strong>, <strong>IDCAMIM_CLIENT_SECRET</strong> e <strong>IDCAMIM_REDIRECT_URI</strong> no <code>.env</code> do sistema e reinicie o serviço.
          </p>
        </div>
      <% } %>

      <% if (error) { %>
        <div class="flash-error" style="margin-bottom:20px;">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          <%= error %>
        </div>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="flash-success" style="margin-bottom:20px;">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <%= success %>
        </div>
      <% } %>

      <!-- Cadastrar novo sistema -->
      <div class="table-container" style="margin-bottom:28px;">
        <div style="padding:20px 24px 16px;border-bottom:1px solid var(--border);">
          <h2 style="font-size:1rem;font-weight:600;color:var(--text-primary);">Registrar novo sistema</h2>
        </div>
        <form method="POST" action="/painel/sistemas" style="padding:20px 24px 24px;display:flex;flex-direction:column;gap:14px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
            <div>
              <label style="display:block;font-size:0.875rem;font-weight:500;margin-bottom:6px;">Nome do sistema</label>
              <input type="text" name="client_name" required placeholder="Ex: Portal RH" class="form-input" />
            </div>
            <div>
              <label style="display:block;font-size:0.875rem;font-weight:500;margin-bottom:6px;">URL de callback (redirect_uri)</label>
              <input type="url" name="redirect_uri" required placeholder="https://sistema.com.br/auth/callback" class="form-input" />
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
            <div>
              <label style="display:block;font-size:0.875rem;font-weight:500;margin-bottom:6px;">URL pós-logout <span style="color:var(--text-muted);font-weight:400;">(opcional)</span></label>
              <input type="url" name="post_logout_uri" placeholder="https://sistema.com.br" class="form-input" />
            </div>
            <div>
              <label style="display:block;font-size:0.875rem;font-weight:500;margin-bottom:6px;">Descrição <span style="color:var(--text-muted);font-weight:400;">(opcional)</span></label>
              <input type="text" name="description" placeholder="Breve descrição do sistema" class="form-input" />
            </div>
          </div>
          <div>
            <button type="submit" class="btn-primary" style="width:auto;padding:10px 28px;margin-top:0;">Registrar e gerar credenciais</button>
          </div>
        </form>
      </div>

      <!-- Lista -->
      <div class="table-container">
        <div style="padding:20px 24px 16px;border-bottom:1px solid var(--border);">
          <h2 style="font-size:1rem;font-weight:600;color:var(--text-primary);">Sistemas registrados</h2>
        </div>
        <% if (clients.length === 0) { %>
          <p style="padding:32px 24px;color:var(--text-muted);font-size:0.9rem;">Nenhum sistema registrado ainda.</p>
        <% } else { %>
          <div style="overflow-x:auto;">
            <table>
              <thead>
                <tr>
                  <th>Nome</th>
                  <th>client_id</th>
                  <th>Redirect URIs</th>
                  <th>Pós-logout</th>
                  <th>Status</th>
                  <th>Criado em</th>
                  <th>Ações</th>
                </tr>
              </thead>
              <tbody>
                <% clients.forEach(function(c) { %>
                  <tr>
                    <td data-label="Nome">
                      <strong><%= c.client_name %></strong>
                      <% if (c.description) { %><br><span style="font-size:0.8rem;color:var(--text-secondary);"><%= c.description %></span><% } %>
                    </td>
                    <td data-label="Client ID">
                      <code style="font-size:0.78rem;background:#f3f4f6;padding:2px 6px;border-radius:4px;word-break:break-all;"><%= c.client_id %></code>
                    </td>
                    <td data-label="Redirect URIs" style="font-size:0.85rem;max-width:220px;word-break:break-all;">
                      <% (c.redirect_uris || []).forEach(function(u) { %><div><%= u %></div><% }); %>
                      <% if (!c.redirect_uris || c.redirect_uris.length === 0) { %><span style="color:var(--text-muted);">—</span><% } %>
                    </td>
                    <td data-label="Pós-logout" style="font-size:0.85rem;max-width:180px;word-break:break-all;">
                      <% (c.post_logout_redirect_uris || []).forEach(function(u) { %><div><%= u %></div><% }); %>
                      <% if (!c.post_logout_redirect_uris || c.post_logout_redirect_uris.length === 0) { %><span style="color:var(--text-muted);">—</span><% } %>
                    </td>
                    <td data-label="Status">
                      <% if (c.active) { %>
                        <span class="badge badge-active">Ativo</span>
                      <% } else { %>
                        <span class="badge badge-inactive">Inativo</span>
                      <% } %>
                    </td>
                    <td data-label="Criado em" style="font-size:0.85rem;white-space:nowrap;color:var(--text-secondary);">
                      <%= new Date(c.created_at).toLocaleDateString('pt-BR') %>
                    </td>
                    <td class="td-actions">
                      <button type="button" class="btn-sm btn-sm-secondary"
                        data-id="<%= c.client_id %>"
                        data-name="<%= c.client_name %>"
                        data-redirect="<%= (c.redirect_uris || []).join('\n') %>"
                        data-logout="<%= (c.post_logout_redirect_uris || []).join('\n') %>"
                        data-desc="<%= c.description || '' %>"
                        onclick="abrirEditarSistema(this)">Editar</button>
                      <% if (c.active) { %>
                        <form method="POST" action="/painel/sistemas/<%= c.client_id %>/desativar" style="display:inline;"
                          onsubmit="return confirm('Desativar este sistema?')">
                          <button type="submit" class="btn-sm btn-sm-danger">Desativar</button>
                        </form>
                      <% } else { %>
                        <form method="POST" action="/painel/sistemas/<%= c.client_id %>/ativar" style="display:inline;">
                          <button type="submit" class="btn-sm btn-sm-primary">Ativar</button>
                        </form>
                      <% } %>
                      <form method="POST" action="/painel/sistemas/<%= c.client_id %>/excluir" style="display:inline;"
                        data-name="<%= c.client_name %>"
                        onsubmit="return confirm('Excluir permanentemente ' + this.dataset.name + '? Não pode ser desfeito.')">
                        <button type="submit" class="btn-sm" style="background:#7f1d1d;color:#fff;">Excluir</button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </main>
  </div>

  <!-- Modal Editar Sistema -->
  <div class="modal-overlay" id="modal-sistema">
    <div class="modal-box">
      <div class="modal-title">Editar sistema</div>
      <form id="form-sistema" method="POST">
        <div class="modal-field">
          <label>Nome do sistema</label>
          <input type="text" id="es-name" name="client_name" required class="form-input" />
        </div>
        <div class="modal-field">
          <label>URLs de callback <span style="color:var(--text-muted);font-weight:400;">(uma por linha)</span></label>
          <textarea id="es-redirect" name="redirect_uris_raw" rows="3" required
            style="width:100%;box-sizing:border-box;padding:9px 12px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:0.875rem;font-family:monospace;resize:vertical;outline:none;transition:border-color 0.15s;"></textarea>
        </div>
        <div class="modal-field">
          <label>URLs pós-logout <span style="color:var(--text-muted);font-weight:400;">(uma por linha, opcional)</span></label>
          <textarea id="es-logout" name="post_logout_uris_raw" rows="2"
            style="width:100%;box-sizing:border-box;padding:9px 12px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:0.875rem;font-family:monospace;resize:vertical;outline:none;transition:border-color 0.15s;"></textarea>
        </div>
        <div class="modal-field">
          <label>Descrição <span style="color:var(--text-muted);font-weight:400;">(opcional)</span></label>
          <input type="text" id="es-desc" name="description" class="form-input" />
        </div>
        <div class="modal-actions">
          <button type="button" class="btn-modal-cancel" onclick="fecharModal('modal-sistema')">Cancelar</button>
          <button type="submit" class="btn-primary" style="width:auto;margin:0;padding:9px 22px;">Salvar alterações</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('admin-sidebar').classList.toggle('open');
      document.getElementById('sidebar-overlay').classList.toggle('open');
    }
    function fecharModal(id) {
      document.getElementById(id).classList.remove('open');
    }
    function copyText(id) {
      const el = document.getElementById(id);
      navigator.clipboard.writeText(el.textContent.trim()).then(() => {
        const btn = el.nextElementSibling;
        const orig = btn.textContent;
        btn.textContent = 'Copiado!';
        btn.style.background = '#15803d';
        setTimeout(() => { btn.textContent = orig; btn.style.background = '#16a34a'; }, 2000);
      });
    }
    function abrirEditarSistema(btn) {
      document.getElementById('es-name').value     = btn.dataset.name;
      document.getElementById('es-redirect').value = btn.dataset.redirect;
      document.getElementById('es-logout').value   = btn.dataset.logout;
      document.getElementById('es-desc').value     = btn.dataset.desc;
      document.getElementById('form-sistema').action = '/painel/sistemas/' + encodeURIComponent(btn.dataset.id) + '/editar';
      document.getElementById('modal-sistema').classList.add('open');
    }
    document.getElementById('modal-sistema').addEventListener('click', function(e) {
      if (e.target === this) fecharModal('modal-sistema');
    });
  </script>
</body>
</html>
