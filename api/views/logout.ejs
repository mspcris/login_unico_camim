<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Sair &mdash; Camim</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="page-wrapper">
    <div class="card">

      <!-- Logo -->
      <div class="logo" aria-label="Camim">
        <svg width="120" height="40" viewBox="0 0 120 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <text x="0" y="32" font-family="system-ui, -apple-system, sans-serif" font-size="30" font-weight="700" fill="#1a56db">Camim</text>
        </svg>
      </div>

      <% if (typeof loggedOut !== 'undefined' && loggedOut) { %>

        <!-- Already logged out state -->
        <div class="logout-icon" aria-hidden="true">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="28" cy="28" r="28" fill="#f0fdf4"/>
            <path d="M23 28l4 4 8-8" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <h1 class="logout-title">Você foi desconectado</h1>
        <p class="logout-subtitle">
          Sua sessão foi encerrada com segurança.<br />
          Você pode fechar esta janela.
        </p>

      <% } else { %>

        <!-- Confirmation state -->
        <div class="logout-icon" aria-hidden="true">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="28" cy="28" r="28" fill="#fefce8"/>
            <path d="M28 20v8" stroke="#ca8a04" stroke-width="2.5" stroke-linecap="round"/>
            <circle cx="28" cy="34" r="1.5" fill="#ca8a04"/>
          </svg>
        </div>

        <h1 class="logout-title">Sair da sua conta?</h1>
        <p class="logout-subtitle">
          Você está prestes a encerrar sua sessão no Login Único Camim.<br />
          Isso encerrará sua sessão em todos os sistemas conectados.
        </p>

        <% if (typeof uid !== 'undefined' && uid) { %>
          <form action="/session/end/confirm" method="POST">
            <% if (typeof xsrf !== 'undefined') { %>
              <input type="hidden" name="xsrf" value="<%= xsrf %>" />
            <% } %>
            <% if (typeof logout !== 'undefined') { %>
              <input type="hidden" name="logout" value="yes" />
            <% } %>
            <button type="submit" class="btn-danger">
              Sair de todas as sessões
            </button>
          </form>
          <form action="/session/end/confirm" method="POST" style="margin-top: 12px">
            <% if (typeof xsrf !== 'undefined') { %>
              <input type="hidden" name="xsrf" value="<%= xsrf %>" />
            <% } %>
            <button type="submit" class="btn-secondary">
              Cancelar
            </button>
          </form>
        <% } else { %>
          <button type="button" class="btn-secondary" onclick="window.history.back()">
            Cancelar
          </button>
        <% } %>

      <% } %>

    </div>

    <!-- Footer -->
    <footer class="page-footer">
      <p>Login Único Camim &mdash; Acesso seguro e centralizado</p>
    </footer>
  </div>
</body>
</html>
