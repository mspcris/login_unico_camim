# =============================================
# Login Único Camim - Configuração de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# --- Ambiente ---
NODE_ENV=production

# --- Banco de Dados PostgreSQL ---
POSTGRES_DB=login_camim
POSTGRES_USER=camim
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

# --- OIDC Provider ---
# URL base do servidor de autenticação (sem barra no final)
ISSUER=https://auth.camim.com.br

# Segredo para assinar cookies (gere com: openssl rand -hex 32)
COOKIE_SECRET=GERE_COM_openssl_rand_hex_32

# --- Admin API ---
# Chave para acessar a API de administração (gere com: openssl rand -hex 32)
ADMIN_API_KEY=GERE_COM_openssl_rand_hex_32

# --- Usuário Admin Inicial ---
ADMIN_EMAIL=admin@camim.com.br
ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

# --- Sessão Web (Painel Administrativo) ---
# Gere com: openssl rand -hex 32
SESSION_SECRET=GERE_COM_openssl_rand_hex_32
